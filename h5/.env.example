# ── Hermes Agent API Server connection ──────────────────────────────
# Base URL of your running Hermes gateway API server.
# Default loopback bind is http://127.0.0.1:8642
HERMES_BASE_URL=http://127.0.0.1:8642

# Bearer token — MUST match the API_SERVER_KEY set in ~/.hermes/.env
HERMES_API_KEY=change-me-local-dev
